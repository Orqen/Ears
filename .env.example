# API authorization
API_KEY=your-secret-api-key

# Yandex Cloud auth
YANDEX_API_KEY=your-yandex-cloud-api-key
YANDEX_FOLDER_ID=your-folder-id
# YC_IAM_TOKEN=optional-iam-token

# Yandex Object Storage (S3-compatible)
YC_S3_ACCESS_KEY=your-s3-access-key
YC_S3_SECRET_KEY=your-s3-secret-key
YC_S3_BUCKET=your-bucket-name

# Google Cloud (for Firestore)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Limits
MAX_AUDIO_SIZE_MB=500
